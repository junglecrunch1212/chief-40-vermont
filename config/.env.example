# PIB v5 Configuration
# Copy to .env and fill in values. chmod 600 .env

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# Google
GOOGLE_SA_KEY_PATH=/opt/pib/config/google-sa-key.json

# BlueBubbles (iMessage bridge)
BLUEBUBBLES_SECRET=
BLUEBUBBLES_URL=http://localhost:1234

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=

# Siri Shortcuts
SIRI_BEARER_TOKEN=

# Backup
BACKUP_PUBLIC_KEY=age1...
BACKUP_FOLDER_ID=

# Google Sheets
PIB_SHEETS_WEBHOOK_TOKEN=

# Database
PIB_DB_PATH=/opt/pib/data/pib.db

# Server
PIB_PORT=3141
PIB_HOST=0.0.0.0

# Logging
PIB_LOG_DIR=/opt/pib/logs

# CORS (comma-separated origins, default * for local dev)
PIB_CORS_ORIGINS=*

# Household
PIB_TIMEZONE=America/New_York

# Runtime mode
PIB_ENV=dev
PIB_STRICT_STARTUP=0
