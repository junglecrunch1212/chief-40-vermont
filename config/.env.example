# PIB v5 Configuration
# Copy to .env and fill in values. chmod 600 .env

# NOTE: OpenClaw manages model routing (ANTHROPIC_API_KEY set via openclaw config)
# and Google auth (gog auth login). These vars are for direct PIB CLI usage.

# ═══════════════════════════════════════════════════════════
# LLM / AI PROVIDERS
# ═══════════════════════════════════════════════════════════

# Anthropic (Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# ═══════════════════════════════════════════════════════════
# MESSAGING / SMS
# ═══════════════════════════════════════════════════════════

# Twilio (SMS fallback)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ═══════════════════════════════════════════════════════════
# GOOGLE SERVICES
# ═══════════════════════════════════════════════════════════

# Google Service Account (for server-side access)
GOOGLE_SA_KEY_PATH=/opt/pib/config/google-sa-key.json

# Google OAuth (for user-based access via gog CLI)
# NOTE: gog auth login handles OAuth flow; these are optional overrides
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback

# Google Sheets (webhook token for inbound edits)
PIB_SHEETS_WEBHOOK_TOKEN=

# ═══════════════════════════════════════════════════════════
# BLUEBUBBLES (iMessage bridges — per-member pattern)
# ═══════════════════════════════════════════════════════════

# Each personal Mac Mini runs BlueBubbles bound to that member's Apple ID.
# Format: BLUEBUBBLES_{MEMBER}_SECRET and BLUEBUBBLES_{MEMBER}_URL

# James's bridge
BLUEBUBBLES_JAMES_SECRET=
BLUEBUBBLES_JAMES_URL=http://james-mini.local:1234

# Laura's bridge
BLUEBUBBLES_LAURA_SECRET=
BLUEBUBBLES_LAURA_URL=http://laura-mini.local:1234

# ═══════════════════════════════════════════════════════════
# SIRI SHORTCUTS
# ═══════════════════════════════════════════════════════════

# Bearer token for Siri Shortcut webhook authentication
SIRI_BEARER_TOKEN=

# ═══════════════════════════════════════════════════════════
# BACKUP & ENCRYPTION
# ═══════════════════════════════════════════════════════════

# Age encryption public key for encrypted backups
BACKUP_PUBLIC_KEY=age1...

# Google Drive folder ID for backup uploads
BACKUP_FOLDER_ID=

# ═══════════════════════════════════════════════════════════
# DATABASE & STORAGE
# ═══════════════════════════════════════════════════════════

# SQLite database path (SSOT)
PIB_DB_PATH=/opt/pib/data/pib.db

# Logging directory
PIB_LOG_DIR=/opt/pib/logs

# ═══════════════════════════════════════════════════════════
# RUNTIME CONFIG
# ═══════════════════════════════════════════════════════════

# Console server port
PIB_CONSOLE_PORT=3333

# Household timezone
PIB_TIMEZONE=America/New_York

# Environment (dev, staging, production)
PIB_ENV=dev

# Strict startup mode (1 = fail on missing deps, 0 = warn and continue)
PIB_STRICT_STARTUP=0

# ═══════════════════════════════════════════════════════════
# AGENT IDENTITY (set by OpenClaw per agent instance)
# ═══════════════════════════════════════════════════════════

# Which agent is calling the CLI (cos, coach, dev, proactive, scoreboard)
# Enforced by cli.py against agent_capabilities.yaml allowlist
PIB_CALLER_AGENT=cos

# ═══════════════════════════════════════════════════════════
# TAILSCALE IDENTITY
# ═══════════════════════════════════════════════════════════
# Tailscale Serve proxies to localhost and injects identity headers.
# Map emails in the database after first boot:
#   UPDATE common_members SET tailscale_email = 'james@gmail.com' WHERE id = 'm-james';
# Start Serve:
#   tailscale serve --bg https+insecure://127.0.0.1:3333
