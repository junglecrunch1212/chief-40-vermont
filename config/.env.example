# PIB v5 Configuration
# Copy to .env and fill in values. chmod 600 .env

# NOTE: OpenClaw manages model routing (ANTHROPIC_API_KEY set via openclaw config)
# and Google auth (gog auth login). These vars are for direct PIB CLI usage.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# Google
GOOGLE_SA_KEY_PATH=/opt/pib/config/google-sa-key.json

# BlueBubbles (iMessage bridge — per-bridge credentials)
# Each personal Mac Mini has its own BlueBubbles instance
BLUEBUBBLES_JAMES_SECRET=
BLUEBUBBLES_JAMES_URL=http://james-mini.local:1234
BLUEBUBBLES_LAURA_SECRET=
BLUEBUBBLES_LAURA_URL=http://laura-mini.local:1234

# Siri Shortcuts
SIRI_BEARER_TOKEN=

# Backup
BACKUP_PUBLIC_KEY=age1...
BACKUP_FOLDER_ID=

# Google Sheets
PIB_SHEETS_WEBHOOK_TOKEN=

# PIB Database
PIB_DB_PATH=/opt/pib/data/pib.db

# Logging
PIB_LOG_DIR=/opt/pib/logs

# Household
PIB_TIMEZONE=America/New_York

# Runtime mode
PIB_ENV=dev
PIB_STRICT_STARTUP=0
